QToolButton {
	min-height: 32px;
	background-color: #36404c;
	color: white;
	border-radius: 8px; 
    font: 8pt; 
    border:1px solid #b6c4d1;
    text-align:center;
    padding-left: 23px;
    padding-right: 18px;
}

QToolButton:disabled {
	background-color: #36404c;
	color: rgb(120, 120, 120);
}

QToolButton:hover {
	background-color: #5e6976;
	color: white;
}

QToolButton:pressed {
	background-color: #36404c;
	color: white;
}

QPushButton#closeBtn {
    border-image: url(:/dark/res/dark/images/titleBar/close.svg);
}

QPushButton#closeBtn:pressed {
    border-image: url(:/dark/res/dark/images/titleBar/close_blue.svg);
}

QTextEdit#textEdit
{
	color:red;
	border-width:0px;
	border-radius:0px;
	border-style:groove;
}

QWidget#PdfReaderGui QCheckBox:enabled {
    color: white;
}

QWidget#PdfReaderGui QCheckBox:!enabled {
    color: gray;
}

QWidget#PdfReaderGui QCheckBox:checked:!enabled {
    color: gray;
}

QWidget#PdfReaderGui QCheckBox:indeterminate:!enabled {
    color: gray;
}

QWidget#PdfReaderGui QCheckBox::indicator {
    width: 13px;
    height: 13px;
}

    QWidget#PdfReaderGui QCheckBox::indicator:unchecked {
        image: url(:/res/dark/images/radio_normal.png);
        color: white;
    }

    QWidget#PdfReaderGui QCheckBox::indicator:checked {
        image: url(:/res/dark/images/radio_pressed.png);
        color: white;
    }

    QWidget#PdfReaderGui QCheckBox::indicator:disabled {
        image: url(:/res/dark/images/radio_disabled.png);
        color: gray;
    }
</string>
